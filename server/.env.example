PORT=4000
MONGODB_URI=mongodb://localhost:27017/authsystem

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=your-access-token-secret-min-64-chars
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-64-chars

# Token lifetimes
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Email (Nodemailer — use Gmail App Password or Mailtrap for dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
EMAIL_FROM=noreply@authsystem.dev

# Frontend URL (for password reset links)
CLIENT_URL=http://localhost:5173
